    stroke.Color = TokenEngine.Get("Border"):Get() stroke.Thickness = 1 stroke.Parent = frame
    
    local lbl = Instance.new("TextButton")
    lbl.Size = UDim2.new(1, -24, 1, 0) lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1 lbl.Text = text .. " :  " .. (options[1] or "Nenhum")
    lbl.TextColor3 = TokenEngine.Get("Text"):Get() lbl.Font = TokenEngine.Get("Font"):Get()
    lbl.TextSize = 13 lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Parent = frame
    
    local listFrame = Instance.new("Frame")
    listFrame.Size = UDim2.new(1, 0, 0, 0) listFrame.Position = UDim2.new(0, 0, 1, 4)
    listFrame.BackgroundColor3 = TokenEngine.Get("Surface"):Get() listFrame.ClipsDescendants = true
    listFrame.Visible = false listFrame.ZIndex = 100 listFrame.Parent = frame
    
    local listCorner = Instance.new("UICorner")
    listCorner.CornerRadius = UDim.new(0, 8) listCorner.Parent = listFrame
    
    local listStroke = Instance.new("UIStroke")
    listStroke.Color = TokenEngine.Get("Border"):Get() listStroke.Thickness = 1 listStroke.Parent = listFrame
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 2) listLayout.Parent = listFrame
    
    local listPadding = Instance.new("UIPadding")
    listPadding.PaddingTop = UDim.new(0, 4) listPadding.PaddingBottom = UDim.new(0, 4)
    listPadding.PaddingLeft = UDim.new(0, 4) listPadding.PaddingRight = UDim.new(0, 4) listPadding.Parent = listFrame
    
    local open = false
    lbl.MouseButton1Click:Connect(function()
        open = not open
        listFrame.Visible = open
        AnalyticalMotion.Link(listFrame, "Size", open and UDim2.new(1, 0, 0, #options * 28 + 8) or UDim2.new(1, 0, 0, 0), 450, 25)
    end)
    
    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, 26) optBtn.BackgroundColor3 = TokenEngine.Get("Surface"):Get()
        optBtn.Text = opt optBtn.TextColor3 = TokenEngine.Get("Muted"):Get()
        optBtn.Font = TokenEngine.Get("Font"):Get() optBtn.TextSize = 12 optBtn.ZIndex = 101 optBtn.Parent = listFrame
        
        local optCorner = Instance.new("UICorner")
        optCorner.CornerRadius = UDim.new(0, 6) optCorner.Parent = optBtn
        
        optBtn.MouseEnter:Connect(function() 
            AnalyticalMotion.Link(optBtn, "BackgroundColor3", TokenEngine.Get("Card"):Get(), 300, 20)
            AnalyticalMotion.Link(optBtn, "TextColor3", TokenEngine.Get("Text"):Get(), 300, 20) 
        end)
        optBtn.MouseLeave:Connect(function() 
            AnalyticalMotion.Link(optBtn, "BackgroundColor3", TokenEngine.Get("Surface"):Get(), 300, 20)
            AnalyticalMotion.Link(optBtn, "TextColor3", TokenEngine.Get("Muted"):Get(), 300, 20) 
        end)
        
        optBtn.MouseButton1Click:Connect(function()
            lbl.Text = text .. " :  " .. opt
            open = false listFrame.Visible = false listFrame.Size = UDim2.new(1, 0, 0, 0)
            
            task.spawn(function()
                local ok, err = pcall(callback, opt)
                if not ok then warn("[KazeUI Error]: " .. tostring(err)) end
            end)
        end)
    end
end

