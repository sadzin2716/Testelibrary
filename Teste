    box.BackgroundColor3 = TokenEngine.Get("Surface"):Get() box.Text = ""
    box.PlaceholderText = placeholder box.PlaceholderColor3 = TokenEngine.Get("Muted"):Get()
    box.TextColor3 = TokenEngine.Get("Text"):Get() box.Font = TokenEngine.Get("Font"):Get()
    box.TextSize = 13 box.ClearTextOnFocus = false box.Parent = frame
    
    box.FocusLost:Connect(function(enterPressed)
        task.spawn(callback, box.Text)
    end)
    self:AddOffset(40)
end

function Page:Dropdown(text: string, options: {string}, callback: (string) -> ())
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 32) frame.Position = UDim2.new(0, 0, 0, self.LayoutOffset)
    frame.BackgroundColor3 = TokenEngine.Get("Surface"):Get() frame.ClipsDescendants = false frame.Parent = self.Container
    
    local lbl = Instance.new("TextButton")
    lbl.Size = UDim2.new(1, 0, 1, 0) lbl.BackgroundTransparency = 1
    lbl.Text = text .. " : " .. (options[1] or "Nenhum") lbl.TextColor3 = TokenEngine.Get("Text"):Get()
    lbl.Font = TokenEngine.Get("Font"):Get() lbl.TextSize = 13 lbl.Parent = frame
    
    local listFrame = Instance.new("Frame")
    listFrame.Size = UDim2.new(1, 0, 0, 0) listFrame.Position = UDim2.new(0, 0, 1, 1)
    listFrame.BackgroundColor3 = TokenEngine.Get("Surface"):Get() listFrame.BorderSizePixel = 1
    listFrame.BorderColor3 = TokenEngine.Get("Border"):Get() listFrame.Visible = false
    listFrame.ZIndex = 10 listFrame.Parent = frame
    
    local open = false
    lbl.MouseButton1Click:Connect(function()
        open = not open
        listFrame.Visible = open
        AnalyticalMotion.Link(listFrame, "Size", open and UDim2.new(1, 0, 0, #options * 26) or UDim2.new(1, 0, 0, 0), 450, 25)
    end)
    
    for idx, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, 25) optBtn.Position = UDim2.new(0, 0, 0, (idx-1) * 26)
        optBtn.BackgroundColor3 = TokenEngine.Get("Surface"):Get() optBtn.BorderSizePixel = 0
        optBtn.Text = opt optBtn.TextColor3 = TokenEngine.Get("Text"):Get()
        optBtn.Font = TokenEngine.Get("Font"):Get() optBtn.TextSize = 12 optBtn.ZIndex = 11 optBtn.Parent = listFrame
        
        optBtn.MouseButton1Click:Connect(function()
            lbl.Text = text .. " : " .. opt
            open = false listFrame.Visible = false listFrame.Size = UDim2.new(1, 0, 0, 0)
            task.spawn(callback, opt)
        end)
    end
    self:AddOffset(38)
end

function Page:Keybind(text: string, default: Enum.KeyCode, callback: () -> ())
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 32) frame.Position = UDim2.new(0, 0, 0, self.LayoutOffset)
    frame.BackgroundTransparency = 1 frame.Parent = self.Container
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -75, 1, 0) lbl.BackgroundTransparency = 1 lbl.Text = text
    lbl.TextColor3 = TokenEngine.Get("Text"):Get() lbl.Font = TokenEngine.Get("Font"):Get()
    lbl.TextSize = 13 lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Parent = frame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 70, 0, 24) btn.Position = UDim2.new(1, -70, 0.5, -12)
    btn.BackgroundColor3 = TokenEngine.Get("Surface"):Get() btn.Text = default.Name
    btn.TextColor3 = TokenEngine.Get("Accent"):Get() btn.Font = TokenEngine.Get("Font"):Get()
    btn.TextSize = 12 btn.Parent = frame
    
    local currentBind = default
    local listening = false
    
    btn.MouseButton1Click:Connect(function()
        listening = true btn.Text = "..."
    end)
    
    game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
        if processed then return end
        if listening and input.UserInputType == Enum.UserInputType.Keyboard then
            currentBind = input.KeyCode listening = false btn.Text = currentBind.Name
        elseif not listening and input.KeyCode == currentBind then
            task.spawn(callback)
        end
    end)
    self:AddOffset(38)
end

