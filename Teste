-- [5] COMPONENTS: BASE COMPONENT & WINDOW INFRASTRUCTURE
-- =============================================================================
local BaseComponent = {}
BaseComponent.__index = BaseComponent
function BaseComponent.new(className: string, tag: string)
    local inst = Instance.new(className) :: any
    inst.BorderSizePixel = 0
    local self = setmetatable({ Id = 0, Instance = inst }, BaseComponent)
    self.Id = Registry.GenerateId(self, tag)
    return self
end
function BaseComponent:Destroy()
    Registry.Destroy(self.Id)
    if self.Instance then self.Instance:Destroy() end
end

-- WINDOW COMPONENT
local Window = {} Window.__index = Window
function Window.new(titleText: string)
    local base = BaseComponent.new("ScreenGui", "KazeUI_Container")
    base.Instance.ResetOnSpawn = false
    base.Instance.Parent = game:GetService("CoreGui") rescue base.Instance.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 520, 0, 360)
    frame.Position = UDim2.new(0.5, -260, 0.5, -180)
    frame.BackgroundColor3 = TokenEngine.Get( "Background" ):Get()
    frame.Active = true frame.Parent = base.Instance
    
    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1, 0, 0, 35)
    titleBar.BackgroundColor3 = TokenEngine.Get("Surface"):Get()
    titleBar.Parent = frame
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -20, 1, 0) titleLabel.Position = UDim2.new(0, 12, 0, 0)
    titleLabel.BackgroundTransparency = 1 titleLabel.Text = titleText
    titleLabel.TextColor3 = TokenEngine.Get("Text"):Get() titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Font = TokenEngine.Get("Font"):Get() titleLabel.TextSize = 14 titleLabel.Parent = titleBar
    
    local container = Instance.new("ScrollingFrame")
    container.Size = UDim2.new(1, -20, 1, -55) container.Position = UDim2.new(0, 10, 0, 45)
    container.BackgroundTransparency = 1 container.CanvasSize = UDim2.new(0, 0, 0, 0)
    container.ScrollBarThickness = 3 container.ScrollBarImageColor3 = TokenEngine.Get("Muted"):Get()
    container.Parent = frame
    
    -- Dragging Handler Integrado O(1)
    local drag, dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            drag = true dragStart = input.Position startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then drag = false end end)
        end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if drag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            AnalyticalMotion.Link(frame, "Position", UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y), 500, 28)
        end
    end)
    
    local self = setmetatable({ Base = base, Frame = frame, Container = container, LayoutOffset = 0 }, Window)
    return self
end

function Window:AddOffset(offset: number)
    self.LayoutOffset += offset
    self.Container.CanvasSize = UDim2.new(0, 0, 0, self.LayoutOffset)
end

