		local isOpened = false

		local dropFrame = Instance.new("Frame")
		dropFrame.Size = UDim2.new(1, 0, 0, 40)
		dropFrame.BackgroundColor3 = Theme.CardBg
		dropFrame.ClipsDescendants = true
		dropFrame.Parent = pageFrame

		local dfCorner = Instance.new("UICorner")
		dfCorner.CornerRadius = UDim.new(0, 8)
		dfCorner.Parent = dropFrame

		local mainBtn = Instance.new("TextButton")
		mainBtn.Size = UDim2.new(1, 0, 0, 40)
		mainBtn.BackgroundTransparency = 1
		mainBtn.Text = "  " .. dropText
		mainBtn.TextColor3 = Theme.TextColor
		mainBtn.Font = Theme.Font
		mainBtn.TextSize = 14
		mainBtn.TextXAlignment = Enum.TextXAlignment.Left
		mainBtn.Parent = dropFrame

		local arrow = Instance.new("TextLabel")
		arrow.Size = UDim2.new(0, 40, 0, 40)
		arrow.Position = UDim2.new(1, -40, 0, 0)
		arrow.BackgroundTransparency = 1
		arrow.Text = "▼"
		arrow.TextColor3 = Theme.TextMuted
		arrow.Font = Theme.Font
		arrow.TextSize = 12
		arrow.Parent = mainBtn

		-- Lista Container
		local listHolder = Instance.new("Frame")
		listHolder.Size = UDim2.new(1, -20, 1, -45)
		listHolder.Position = UDim2.new(0, 10, 0, 42)
		listHolder.BackgroundTransparency = 1
		listHolder.Parent = dropFrame

		local listLayout = Instance.new("UIListLayout")
		listLayout.Padding = UDim.new(0, 4)
		listLayout.Parent = listHolder

		-- População dos botões da lista
		for _, opt in pairs(list) do
			local optBtn = Instance.new("TextButton")
			optBtn.Size = UDim2.new(1, 0, 0, 30)
			optBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
			optBtn.Text = opt
			optBtn.TextColor3 = Theme.TextMuted
			optBtn.Font = Theme.Font
			optBtn.TextSize = 13
			optBtn.Parent = listHolder

			local obc = Instance.new("UICorner")
			obc.CornerRadius = UDim.new(0, 6)
			obc.Parent = optBtn

			optBtn.MouseButton1Click:Connect(function()
				mainBtn.Text = "  " .. dropText .. " (" .. opt .. ")"
				isOpened = false
				CreateTween(dropFrame, 0.2, {Size = UDim2.new(1, 0, 0, 40)})
				CreateTween(arrow, 0.2, {Rotation = 0})
				callback(opt)
			end)
		end

		mainBtn.MouseButton1Click:Connect(function()
			isOpened = not isOpened
			if isOpened then
				local neededHeight = 45 + (#list * 34)
				CreateTween(dropFrame, 0.2, {Size = UDim2.new(1, 0, 0, neededHeight)})
				CreateTween(arrow, 0.2, {Rotation = 180})
			else
				CreateTween(dropFrame, 0.2, {Size = UDim2.new(1, 0, 0, 40)})
				CreateTween(arrow, 0.2, {Rotation = 0})
			end
		end)
	end

	-- [ COMPONENTE: TEXTBOX (CAMPO DE TEXTO) ]
	function elements:CreateTextBox(placeholder, callback)
		callback = callback or function() end

		local boxFrame = Instance.new("Frame")
		boxFrame.Size = UDim2.new(1, 0, 0, 40)
		boxFrame.BackgroundColor3 = Theme.CardBg
		boxFrame.Parent = pageFrame

		local bfCorner = Instance.new("UICorner")
		bfCorner.CornerRadius = UDim.new(0, 8)
		bfCorner.Parent = boxFrame

		local stroke = Instance.new("UIStroke")
		stroke.Thickness = 1
		stroke.Color = Theme.Stroke
		stroke.Parent = boxFrame

		local box = Instance.new("TextBox")
		box.Size = UDim2.new(1, -24, 1, 0)
		box.Position = UDim2.new(0, 12, 0, 0)
		box.BackgroundTransparency = 1
		box.PlaceholderText = placeholder
		box.PlaceholderColor3 = Theme.TextMuted
		box.Text = ""
		box.TextColor3 = Theme.TextColor
		box.Font = Theme.Font
		box.TextSize = 14
		box.TextXAlignment = Enum.TextXAlignment.Left
		box.Parent = boxFrame

		-- Feedback Visual de Foco (Glow Accent)
		box.Focused:Connect(function() CreateTween(stroke, 0.2, {Color = Theme.Accent}) end)
		box.FocusLost:Connect(function(enterPressed) 
			CreateTween(stroke, 0.2, {Color = Theme.Stroke})
			callback(box.Text, enterPressed)
		end)
	end

	return elements
end

