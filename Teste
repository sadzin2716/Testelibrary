		valLabel.Font = Theme.Font
		valLabel.TextSize = 14
		valLabel.TextXAlignment = Enum.TextXAlignment.Right
		valLabel.Parent = sliderFrame

		-- Trilha do Slider
		local track = Instance.new("TextButton")
		track.Size = UDim2.new(1, -24, 0, 6)
		track.Position = UDim2.new(0, 12, 0, 34)
		track.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
		track.Text = ""
		track.Parent = sliderFrame

		local trCorner = Instance.new("UICorner")
		trCorner.CornerRadius = UDim.new(1, 0)
		trCorner.Parent = track

		local fill = Instance.new("Frame")
		fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
		fill.BackgroundColor3 = Theme.Accent
		fill.BorderSizePixel = 0
		fill.Parent = track

		local fillCorner = Instance.new("UICorner")
		fillCorner.CornerRadius = UDim.new(1, 0)
		fillCorner.Parent = fill

		-- Lógica de Arrastar com Mouse/Touch
		local snap = Instance.new("Frame") -- Knob oculto/área ampliada para toque fácil
		snap.Size = UDim2.new(0, 16, 0, 16)
		snap.Position = UDim2.new((value - min) / (max - min), -8, 0.5, -8)
		snap.BackgroundColor3 = Theme.TextColor
		snap.Parent = track

		local snCorner = Instance.new("UICorner")
		snCorner.CornerRadius = UDim.new(1, 0)
		snCorner.Parent = snap

		local sliding = false

		local function UpdateSlider(input)
			local percentage = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteWidth, 0, 1)
			value = math.floor(min + (max - min) * percentage)
			valLabel.Text = tostring(value)
			CreateTween(fill, 0.1, {Size = UDim2.new(percentage, 0, 1, 0)})
			CreateTween(snap, 0.1, {Position = UDim2.new(percentage, -8, 0.5, -8)})
			callback(value)
		end

		track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				sliding = true
				UpdateSlider(input)
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				UpdateSlider(input)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				sliding = false
			end
		end)
	end

