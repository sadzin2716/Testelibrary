local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

local ModernUI = {}
ModernUI.__index = ModernUI

-- Configurações de Animação
local TWEEN_INFO = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

function ModernUI.new(titleText: string)
	local self = setmetatable({}, ModernUI)
	
	-- ScreenGui Principal
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "ModernLibraryGui"
	screenGui.ResetOnSpawn = false
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
	
	-- Container Principal (Responsivo usando Scale + AnchorPoint)
	local mainFrame = Instance.new("Frame")
	mainFrame.Name = "MainFrame"
	mainFrame.Size = UDim2.new(0.4, 0, 0.5, 0) -- Ajusta proporcionalmente à tela
	mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
	mainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
	mainFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
	mainFrame.BorderSizePixel = 0
	mainFrame.Parent = screenGui
	
	-- Regra de Limite de Escala (Evita ficar minusculo ou gigante em celulares)
	local sizeConstraint = Instance.new("UISizeConstraint")
	sizeConstraint.MinSize = Vector2.new(280, 220)
	sizeConstraint.MaxSize = Vector2.new(500, 400)
	sizeConstraint.Parent = mainFrame

	-- Design do MainFrame
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = mainFrame

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(50, 50, 65)
	stroke.Thickness = 1.5
	stroke.Parent = mainFrame

	-- Título
	local titleLabel = Instance.new("TextLabel")
	titleLabel.Size = UDim2.new(1, -20, 0, 40)
	titleLabel.Position = UDim2.new(0, 12, 0, 5)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = titleText or "UI Library"
	titleLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.Font = Enum.Font.BuilderSansBold
	titleLabel.TextSize = 18
	titleLabel.Parent = mainFrame

	-- Lista/Container de Elementos (Com Scroll)
	local container = Instance.new("ScrollingFrame")
	container.Size = UDim2.new(1, -24, 1, -55)
	container.Position = UDim2.new(0, 12, 0, 45)
	container.BackgroundTransparency = 1
	container.ScrollBarThickness = 3
	container.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 100)
	container.CanvasSize = UDim2.new(0, 0, 0, 0)
	container.AutomaticCanvasSize = Enum.AutomaticSize.Y
	container.Parent = mainFrame

	local listLayout = Instance.new("UIListLayout")
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder
	listLayout.Padding = UDim.new(0, 8)
	listLayout.Parent = container

	self.Container = container
	self.ScreenGui = screenGui
	return self
end

-- Componente: Botão
function ModernUI:CreateButton(text: string, callback: () -> ())
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, -4, 0, 36)
	button.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
	button.Text = text
	button.TextColor3 = Color3.fromRGB(220, 220, 230)
	button.Font = Enum.Font.BuilderSans
	button.TextSize = 14
	button.AutoButtonColor = false
	button.Parent = self.Container

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = button

	-- Animações de Interação (Hover & Touch)
	button.MouseEnter:Connect(function()
		TweenService:Create(button, TWEEN_INFO, {BackgroundColor3 = Color3.fromRGB(45, 45, 60)}):Play()
	end)
	button.MouseLeave:Connect(function()
		TweenService:Create(button, TWEEN_INFO, {BackgroundColor3 = Color3.fromRGB(35, 35, 45)}):Play()
	end)
	
	button.Activated:Connect(function()
		-- Pequeno efeito de clique ("feedback tátil")
		TweenService:Create(button, TWEEN_INFO, {Size = UDim2.new(0.97, -4, 0, 34)}):Play()
		task.wait(0.08)
		TweenService:Create(button, TWEEN_INFO, {Size = UDim2.new(1, -4, 0, 36)}):Play()
		
		if callback then callback() end
	end)
end

-- Componente: Toggle (Chave Liga/Desliga)
function ModernUI:CreateToggle(text: string, defaultState: boolean, callback: (boolean) -> ())
	local state = defaultState or false

	local toggleFrame = Instance.new("Frame")
	toggleFrame.Size = UDim2.new(1, -4, 0, 38)
	toggleFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
	toggleFrame.Parent = self.Container

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = toggleFrame

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.7, 0, 1, 0)
	label.Position = UDim2.new(0, 10, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = text
	label.TextColor3 = Color3.fromRGB(220, 220, 230)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Font = Enum.Font.BuilderSans
	label.TextSize = 14
	label.Parent = toggleFrame

	-- Switch (O fundo da chavinha)
	local switchBg = Instance.new("TextButton")
	switchBg.Size = UDim2.new(0, 42, 0, 22)
	switchBg.Position = UDim2.new(1, -50, 0.5, -11)
	switchBg.BackgroundColor3 = state and Color3.fromRGB(0, 180, 120) or Color3.fromRGB(60, 60, 75)
	switchBg.Text = ""
	switchBg.AutoButtonColor = false
	switchBg.Parent = toggleFrame

	local switchCorner = Instance.new("UICorner")
	switchCorner.CornerRadius = UDim.new(1, 0)
	switchCorner.Parent = switchBg

	-- Knob (A bolinha sliding)
	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 16, 0, 16)
	knob.Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
	knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	knob.BorderSizePixel = 0
	knob.Parent = switchBg

	local knobCorner = Instance.new("UICorner")
	knobCorner.CornerRadius = UDim.new(1, 0)
	knobCorner.Parent = knob

	-- Evento de Clique/Toque no Celular
	switchBg.Activated:Connect(function()
		state = not state
		local targetColor = state and Color3.fromRGB(0, 180, 120) or Color3.fromRGB(60, 60, 75)
		local targetPos = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)

		TweenService:Create(switchBg, TWEEN_INFO, {BackgroundColor3 = targetColor}):Play()
		TweenService:Create(knob, TWEEN_INFO, {Position = targetPos}):Play()

		if callback then callback(state) end
	end)
end

return ModernUI
