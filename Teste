function Page:Keybind(text: string, default: Enum.KeyCode, callback: () -> ())
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 40) frame.BackgroundColor3 = TokenEngine.Get("Surface"):Get()
    frame.Parent = self.Container
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8) corner.Parent = frame
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = TokenEngine.Get("Border"):Get() stroke.Thickness = 1 stroke.Parent = frame
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -110, 1, 0) lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1 lbl.Text = text
    lbl.TextColor3 = TokenEngine.Get("Text"):Get() lbl.Font = TokenEngine.Get("Font"):Get()
    lbl.TextSize = 13 lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Parent = frame
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 86, 0, 26) btn.Position = UDim2.new(1, -98, 0.5, -13)
    btn.BackgroundColor3 = TokenEngine.Get("Card"):Get() btn.Text = default.Name
    btn.TextColor3 = TokenEngine.Get("AccentGlow"):Get() btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11 btn.AutoButtonColor = false btn.Parent = frame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6) btnCorner.Parent = btn
    
    local currentBind = default
    local listening = false
    
    btn.MouseButton1Click:Connect(function() listening = true btn.Text = "..." end)
    
    game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
        if processed then return end
        if listening and input.UserInputType == Enum.UserInputType.Keyboard then
            currentBind = input.KeyCode listening = false btn.Text = currentBind.Name
        elseif not listening and input.KeyCode == currentBind then
            task.spawn(function()
                local ok, err = pcall(callback)
                if not ok then warn("[KazeUI Error]: " .. tostring(err)) end
            end)
        end
    end)
end

