function Window:SelectTab(name: string)
    local old = self.CurrentTab:Get()
    if old == name then return end
    self.CurrentTab:Set(name)
    
    for tName, page in pairs(self.Tabs) do
        local isTarget = (tName == name)
        page.Container.Visible = isTarget
        
        local tabObj = self.TabButtons[tName]
        if tabObj then
            local targetBg = isTarget and TokenEngine.Get("Surface"):Get() or TokenEngine.Get("Sidebar"):Get()
            local targetText = isTarget and TokenEngine.Get("Text"):Get() or TokenEngine.Get("Muted"):Get()
            local targetIndTrans = isTarget and 0 or 1
            
            AnalyticalMotion.Link(tabObj.Button, "BackgroundColor3", targetBg, 400, 22)
            AnalyticalMotion.Link(tabObj.Label, "TextColor3", targetText, 400, 22)
            AnalyticalMotion.Link(tabObj.Indicator, "BackgroundTransparency", targetIndTrans, 400, 22)
        end
    end
end

