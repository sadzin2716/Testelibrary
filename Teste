-- [6] COMPONENTES DE INTERAÇÃO (BUTTON, TOGGLE, SLIDER)
-- =============================================================================
function Window:Button(text: string, callback: () -> ())
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 32) btn.Position = UDim2.new(0, 0, 0, self.LayoutOffset)
    btn.BackgroundColor3 = TokenEngine.Get("Surface"):Get() btn.Text = text
    btn.TextColor3 = TokenEngine.Get("Text"):Get() btn.Font = TokenEngine.Get("Font"):Get()
    btn.TextSize = 13 btn.Parent = self.Container
    
    btn.MouseEnter:Connect(function() AnalyticalMotion.Link(btn, "BackgroundColor3", TokenEngine.Get("Border"):Get(), 400, 20) end)
    btn.MouseLeave:Connect(function() AnalyticalMotion.Link(btn, "BackgroundColor3", TokenEngine.Get("Surface"):Get(), 400, 20) end)
    btn.MouseButton1Click:Connect(callback)
    self:AddOffset(38)
end

function Window:Toggle(text: string, default: boolean, callback: (boolean) -> ())
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 30) frame.Position = UDim2.new(0, 0, 0, self.LayoutOffset)
    frame.BackgroundTransparency = 1 frame.Parent = self.Container
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -45, 1, 0) lbl.BackgroundTransparency = 1 lbl.Text = text
    lbl.TextColor3 = TokenEngine.Get("Text"):Get() lbl.Font = TokenEngine.Get("Font"):Get()
    lbl.TextSize = 13 lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Parent = frame
    
    local box = Instance.new("TextButton")
    box.Size = UDim2.new(0, 38, 0, 20) box.Position = UDim2.new(1, -38, 0.5, -10)
    box.BackgroundColor3 = TokenEngine.Get("Surface"):Get() box.Text = "" box.Parent = frame
    
    local inner = Instance.new("Frame")
    inner.Size = UDim2.new(0, 14, 0, 14) inner.Position = UDim2.new(0, 3, 0.5, -7)
    inner.BackgroundColor3 = TokenEngine.Get("Muted"):Get() inner.BorderSizePixel = 0 inner.Parent = box
    
    local state = StateGraph.CreateState(default)
    StateGraph.Observe(state, function(v)
        local targetX = v and 21 or 3
        local color = v and TokenEngine.Get("Accent"):Get() or TokenEngine.Get("Muted"):Get()
        AnalyticalMotion.Link(inner, "Position", UDim2.new(0, targetX, 0.5, -7), 450, 24)
        AnalyticalMotion.Link(inner, "BackgroundColor3", color, 450, 24)
        task.spawn(callback, v)
    end)
    box.MouseButton1Click:Connect(function() state:Set(not state:Get()) end)
    self:AddOffset(36)
end

function Window:Slider(text: string, min: number, max: number, default: number, callback: (number) -> ())
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 45) frame.Position = UDim2.new(0, 0, 0, self.LayoutOffset)
    frame.BackgroundTransparency = 1 frame.Parent = self.Container
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.7, 0, 0, 20) lbl.BackgroundTransparency = 1 lbl.Text = text
    lbl.TextColor3 = TokenEngine.Get("Text"):Get() lbl.Font = TokenEngine.Get("Font"):Get()
    lbl.TextSize = 13 lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Parent = frame
    
    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0.3, 0, 0, 20) valLbl.Position = UDim2.new(0.7, 0, 0, 0)
    valLbl.BackgroundTransparency = 1 valLbl.Text = tostring(default)
    valLbl.TextColor3 = TokenEngine.Get("Muted"):Get() valLbl.Font = TokenEngine.Get("Font"):Get()
    valLbl.TextSize = 13 valLbl.TextXAlignment = Enum.TextXAlignment.Right valLbl.Parent = frame
    
    local track = Instance.new("TextButton")
    track.Size = UDim2.new(1, 0, 0, 6) track.Position = UDim2.new(0, 0, 0, 25)
    track.BackgroundColor3 = TokenEngine.Get("Surface"):Get() track.Text = "" track.Parent = frame
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default - min)/(max - min), 0, 1, 0)
    fill.BackgroundColor3 = TokenEngine.Get("Accent"):Get() fill.BorderSizePixel = 0 fill.Parent = track
    
    local state = StateGraph.CreateState(default)
    local drag = false
    
    local function snap(input: InputObject)
        local w = track.AbsoluteSize.X if w == 0 then return end
        local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / w, 0, 1)
        local val = math.round((min + (pct * (max - min))) * 100) / 100
        state:Set(val)
    end
    
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            drag = true snap(input)
        end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if drag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            snap(input)
        end
    end)
    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then drag = false end
    end)
    
    StateGraph.Observe(state, function(v)
        valLbl.Text = tostring(v)
        AnalyticalMotion.Link(fill, "Size", UDim2.new((v - min)/(max - min), 0, 1, 0), 400, 25)
        task.spawn(callback, v)
    end)
    self:AddOffset(52)
end

