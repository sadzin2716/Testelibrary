	minimizeBtn.Font = Theme.Font
	minimizeBtn.TextSize = 28
	minimizeBtn.Parent = self.TopBar

	-- Mesmos efeitos de hover/transição do botão fechar
	minimizeBtn.MouseEnter:Connect(function() CreateTween(minimizeBtn, 0.2, {TextColor3 = Theme.Accent}) end)
	minimizeBtn.MouseLeave:Connect(function() CreateTween(minimizeBtn, 0.2, {TextColor3 = Theme.TextMuted}) end)

	-- Funcionalidade de minimizar
	local function minimizeWindow()
		-- Anima o MainFrame para tamanho zero e depois oculta
		CreateTween(self.MainFrame, 0.3, {Size = UDim2.new(0, 0, 0, 0)})
		task.wait(0.3)
		self.MainFrame.Visible = false

		-- Cria/Exibe o botão flutuante para reabrir
		if not self.FloatingBtn then
			local floater = Instance.new("ImageButton")
			floater.Name = "MinimizeFloater"
			floater.Size = UDim2.new(0, 56, 0, 56) -- botão discreto
			floater.Position = UDim2.new(0, 16, 1, -80) -- canto inferior esquerdo
			floater.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
			floater.BackgroundTransparency = 0.3
			floater.Image = "rbxassetid://72939763737478"
			floater.ScaleType = Enum.ScaleType.Fit
			floater.ImageTransparency = 0.1
			floater.AutoButtonColor = false
			floater.Parent = self.ScreenGui

			-- Arredondado (circular)
			local floaterCorner = Instance.new("UICorner")
			floaterCorner.CornerRadius = UDim.new(1, 0)
			floaterCorner.Parent = floater

			-- Efeito de hover sutil
			floater.MouseEnter:Connect(function()
				CreateTween(floater, 0.2, {BackgroundTransparency = 0.1})
			end)
			floater.MouseLeave:Connect(function()
				CreateTween(floater, 0.2, {BackgroundTransparency = 0.3})
			end)

			-- Torna o botão flutuante arrastável (mobile-friendly)
			local dragStartPos, startBtnPos
			floater.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragStartPos = input.Position
					startBtnPos = floater.Position
					input.Changed:Connect(function()
						if input.UserInputState == Enum.UserInputState.End then
							dragStartPos = nil
						end
					end)
				end
			end)
			floater.InputChanged:Connect(function(input)
				if dragStartPos and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					local delta = input.Position - dragStartPos
					floater.Position = UDim2.new(
						startBtnPos.X.Scale,
						startBtnPos.X.Offset + delta.X,
						startBtnPos.Y.Scale,
						startBtnPos.Y.Offset + delta.Y
					)
				end
			end)

			-- Clique para reabrir a janela
			floater.MouseButton1Click:Connect(function()
				floater.Visible = false
				self.MainFrame.Visible = true
				CreateTween(self.MainFrame, 0.3, {Size = self.OriginalSize})
			end)

			self.FloatingBtn = floater
		else
			self.FloatingBtn.Visible = true
		end
	end

	minimizeBtn.MouseButton1Click:Connect(minimizeWindow)
	-- ================================================================

	-- Sidebar (Menu de Navegação Lateral)
	self.Sidebar = Instance.new("Frame")
	self.Sidebar.Name = "Sidebar"
	self.Sidebar.Size = UDim2.new(0, 130, 1, -45)
	self.Sidebar.Position = UDim2.new(0, 0, 0, 45)
	self.Sidebar.BackgroundColor3 = Theme.Sidebar
	self.Sidebar.Parent = self.MainFrame

	local sideLayout = Instance.new("UIListLayout")
	sideLayout.Padding = UDim.new(0, 5)
	sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	sideLayout.SortOrder = Enum.SortOrder.LayoutOrder
	sideLayout.Parent = self.Sidebar

	local sidePadding = Instance.new("UIPadding")
	sidePadding.PaddingTop = UDim.new(0, 10)
	sidePadding.Parent = self.Sidebar

	-- Container de Páginas (Onde os scripts/elementos vão ficar)
	self.PageContainer = Instance.new("Frame")
	self.PageContainer.Name = "PageContainer"
	self.PageContainer.Size = UDim2.new(1, -140, 1, -55)
	self.PageContainer.Position = UDim2.new(0, 135, 0, 50)
	self.PageContainer.BackgroundTransparency = 1
	self.PageContainer.Parent = self.MainFrame

	self.Pages = {}
	self.Tabs = {}
	self.FirstPage = nil

	-- Animação de entrada Premium
	self.MainFrame.Size = UDim2.new(0, 0, 0, 0)
	CreateTween(self.MainFrame, 0.4, {Size = self.OriginalSize})

	return self
end

-- [[ CRIADOR DE ABAS (PÁGINAS) ]]
function Muzysh:CreatePage(pageName)
	local pageId = #self.Pages + 1

	-- Frame da Página de Conteúdo (Scrolling para suportar infinitos componentes)
	local pageFrame = Instance.new("ScrollingFrame")
	pageFrame.Name = pageName .. "_Page"
	pageFrame.Size = UDim2.new(1, 0, 1, 0)
	pageFrame.BackgroundTransparency = 1
	pageFrame.ScrollBarThickness = 2
	pageFrame.ScrollBarImageColor3 = Theme.Accent
	pageFrame.Visible = false
	pageFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
	pageFrame.Parent = self.PageContainer

	local pageLayout = Instance.new("UIListLayout")
	pageLayout.Padding = UDim.new(0, 8)
	pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
	pageLayout.Parent = pageFrame

	pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		pageFrame.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 15)
	end)

	local pagePadding = Instance.new("UIPadding")
	pagePadding.PaddingLeft = UDim.new(0, 5)
	pagePadding.PaddingRight = UDim.new(0, 10)
	pagePadding.PaddingTop = UDim.new(0, 5)
	pagePadding.Parent = pageFrame

	-- Botão da Aba na Sidebar
	local tabBtn = Instance.new("TextButton")
	tabBtn.Name = pageName .. "_Tab"
	tabBtn.Size = UDim2.new(0, 115, 0, 35)
	tabBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	tabBtn.BackgroundTransparency = 1
	tabBtn.Text = "  " .. pageName
	tabBtn.TextColor3 = Theme.TextMuted
	tabBtn.Font = Theme.Font
	tabBtn.TextSize = 14
	tabBtn.TextXAlignment = Enum.TextXAlignment.Left
	tabBtn.Parent = self.Sidebar

	local tabCorner = Instance.new("UICorner")
	tabCorner.CornerRadius = UDim.new(0, 6)
	tabCorner.Parent = tabBtn

	-- Indicador Lateral Ativo (Visual Premium)
	local indicator = Instance.new("Frame")
	indicator.Size = UDim2.new(0, 3, 0, 0)
	indicator.Position = UDim2.new(0, 0, 0.5, 0)
	indicator.BackgroundColor3 = Theme.Accent
	indicator.BorderSizePixel = 0
	indicator.Parent = tabBtn

	-- Mecânica de Alternância de Abas
	local function SelectPage()
		for _, p in pairs(self.Pages) do p.Visible = false end
		for t, ind in pairs(self.Tabs) do 
			CreateTween(t, 0.2, {TextColor3 = Theme.TextMuted, BackgroundTransparency = 1})
			CreateTween(ind, 0.2, {Size = UDim2.new(0, 3, 0, 0), Position = UDim2.new(0, 0, 0.5, 0)})
		end
		pageFrame.Visible = true
		CreateTween(tabBtn, 0.2, {TextColor3 = Theme.TextColor, BackgroundTransparency = 0.8})
		CreateTween(indicator, 0.2, {Size = UDim2.new(0, 3, 0, 18), Position = UDim2.new(0, 0, 0.25, 0)})
	end

	tabBtn.MouseButton1Click:Connect(SelectPage)
	self.Pages[pageId] = pageFrame
	self.Tabs[tabBtn] = indicator

	if not self.FirstPage then
		self.FirstPage = SelectPage
		task.spawn(SelectPage)
	end

