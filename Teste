function Page:AddOffset(offset: number)
    self.LayoutOffset += offset
    self.Container.CanvasSize = UDim2.new(0, 0, 0, self.LayoutOffset)
end

function Window:Tab(name: string)
    local page = Page.new(self.PagesContainer)
    self.Tabs[name] = page
    table.insert(self.TabOrder, name)
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 90, 1, -2) btn.BackgroundColor3 = TokenEngine.Get("Surface"):Get()
    btn.BorderSizePixel = 0 btn.Text = name btn.TextColor3 = TokenEngine.Get("Muted"):Get()
    btn.Font = TokenEngine.Get("Font"):Get() btn.TextSize = 12 btn.Parent = self.TabBar
    
    -- Redesenhar guias horizontais ordenadas de forma manual
    for idx, tName in ipairs(self.TabOrder) do
        local tBtn = self.TabBar:GetChildren()[idx]
        if tBtn and tBtn:IsA("GuiObject") then tBtn.Position = UDim2.new(0, (idx-1) * 92 + 5, 0, 2) end
    end
    
    btn.MouseButton1Click:Connect(function() self:SelectTab(name) end)
    if self.CurrentTab:Get() == "" then self:SelectTab(name) end
    return page
end

function Window:SelectTab(name: string)
    local old = self.CurrentTab:Get()
    if old == name then return end
    self.CurrentTab:Set(name)
    
    for tName, page in pairs(self.Tabs) do
        page.Container.Visible = (tName == name)
    end
end

