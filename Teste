	local function UpdateScale()
		local viewportSize = workspace.CurrentCamera.ViewportSize
		if viewportSize.X < 600 or viewportSize.Y < 400 then
			uiScale.Scale = math.min(viewportSize.X / 620, viewportSize.Y / 400)
		else
			uiScale.Scale = 1
		end
	end
